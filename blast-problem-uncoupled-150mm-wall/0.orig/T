{
    leftWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    rightWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    lowerWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    upperWall
    {
        type            fixedValue;
        value           uniform 300;
    }

    interface
    {
        type            fixedValue;
        value           uniform 300;
    }
    
    front
    {
        type            symmetryPlane;
    }

    back
    {
        type            symmetryPlane;
    }
}